# Environment Configuration for GridCharge

# Database
DATABASE_URL=postgresql://gridcharge:password@localhost:5432/gridcharge

# Redis
REDIS_URL=redis://localhost:6379/0

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# Frontend
REACT_APP_API_URL=http://localhost:8000

# Grid Configuration
NOMINAL_FREQUENCY_HZ=50.0
GSI_CRITICAL_THRESHOLD=75.0

# V2G Configuration
V2G_MIN_SOC=60.0
V2G_MAX_DISCHARGE_KW=10.0
V2G_DISCHARGE_RATE_PER_KWH=2.5

# Charging Station
STATION_CAPACITY_KW=1000.0
NUM_CHARGING_SLOTS=50
