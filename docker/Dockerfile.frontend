# Frontend Dockerfile
FROM node:18-alpine AS builder

WORKDIR /app

ARG REACT_APP_API_URL=http://gridcharge-api:8000

COPY package*.json ./
RUN npm ci

COPY public ./public
COPY src ./src

ENV REACT_APP_API_URL=${REACT_APP_API_URL}
RUN npm run build

FROM node:18-alpine

WORKDIR /app

COPY --from=builder /app/build ./public

EXPOSE 3000

# Use serve to host the static React SPA with proper routing
CMD ["npx", "serve", "-s", "public", "-l", "3000"]
